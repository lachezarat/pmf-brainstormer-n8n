N8N_PORT=5678
N8N_BASIC_AUTH_ACTIVE=true
N8N_BASIC_AUTH_USER=admin
N8N_BASIC_AUTH_PASSWORD=change-me
N8N_HOST=localhost
N8N_PROTOCOL=http
WEBHOOK_URL=http://localhost:5678/

POSTGRES_DB=n8n
POSTGRES_USER=n8n
POSTGRES_PASSWORD=n8n

GEMINI_API_KEY=replace-me
GEMINI_MODEL=gemini-3-flash-preview
EXA_API_KEY=replace-me

# Airtable control plane:
# 1. create the base and tables described in docs/airtable-setup.md
# 2. import the templates from fixtures/airtable/
# 3. set enabled=true and restart n8n
AIRTABLE_CONTROL_PLANE_ENABLED=false
AIRTABLE_TOKEN=replace-me
AIRTABLE_BASE_ID=replace-me
AIRTABLE_RUNS_TABLE=Runs
AIRTABLE_STAGE_ATTEMPTS_TABLE=Stage Attempts
AIRTABLE_GATE_DECISIONS_TABLE=Gate Decisions
AIRTABLE_EXPERIMENTS_TABLE=Experiments
AIRTABLE_PROMPT_CONFIGS_TABLE=Prompt Configs
